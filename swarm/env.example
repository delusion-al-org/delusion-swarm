# ===========================================
# delusion-swarm — Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values:
#   cp env.example .env

# --- LLM Providers ---

# OpenRouter (unified gateway for free/mid tiers)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Anthropic (direct access for boost/premium tiers)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI (alternative for boost/premium tiers)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Ollama (local free-tier fallback)
# Install: https://ollama.com — no key needed
OLLAMA_BASE_URL=http://localhost:11434

# NVIDIA NIM (high-performance free-tier)
# Get keys at: https://build.nvidia.com/
# Multi-key rotation: Provide comma-separated keys to avoid 40 RPM limit
# Example: NVIDIA_API_KEY=nvapi-key1,nvapi-key2,nvapi-key3
NVIDIA_API_KEY=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,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,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

# --- Per-Agent Model Chains (comma-separated, first available wins) ---
# Format: provider/model-id (e.g. openrouter/google/gemma-2-27b-it:free)
ORCHESTRATOR_MODELS=nvidia/google/gemma-4-31b-it,nvidia/meta/llama-3.1-405b-instruct,openrouter/google/gemma-2-27b-it:free
SCOUT_MODELS=nvidia/google/gemma-4-31b-it,nvidia/meta/llama-3.1-405b-instruct,openrouter/meta-llama/llama-3.3-70b:free
FORGE_MODELS=nvidia/google/gemma-4-31b-it,nvidia/meta/llama-3.1-405b-instruct,openrouter/google/gemma-2-27b-it:free
DEPLOYER_MODELS=ollama/gemma2:9b
MAINTAINER_MODELS=nvidia/google/gemma-4-31b-it,nvidia/meta/llama-3.1-405b-instruct,openrouter/google/gemma-2-27b-it:free

# --- Runtime ---
NODE_ENV=development
PORT=4111

# --- Security ---
# Comma-separated allowlist for bash-exec tool in production
# Default (if unset): git,bun,curl,cp,mv,mkdir,cat,ls,echo
BASH_ALLOWLIST=
