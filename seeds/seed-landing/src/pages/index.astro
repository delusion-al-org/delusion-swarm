---
import { getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import HeroSection from '@delusion/blocks/components/HeroSection.astro';
import MenuSection from '@delusion/blocks/components/MenuSection.astro';
import ContactSection from '@delusion/blocks/components/ContactSection.astro';

// Dynamic mapping of blocks requested by Forge
const BlocksMap: Record<string, any> = {
  HeroSection,
  MenuSection,
  ContactSection
};

const businessData = await getEntry('business', 'delusion');
const { sections, business } = businessData.data;
---
<Layout>
  {sections.map((section) => {
    const Component = BlocksMap[section.block];
    
    if (!Component) {
      if (import.meta.env.DEV) {
        return <div style="color:red; padding: 1rem; border: 1px dashed red;">Unknown block: {section.block}</div>;
      }
      return null;
    }

    // Pass down the block props generated by the Forge Agent
    // We also inject the global business context just in case the block needs global data
    return <Component {...section.props} business={business} />;
  })}
</Layout>
