# ===========================================
# delusion-swarm — Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values:
#   cp env.example .env

# --- LLM Providers ---

# OpenRouter (unified gateway for free/mid tiers)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Anthropic (direct access for boost/premium tiers)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI (alternative for boost/premium tiers)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Ollama (local free-tier fallback)
# Install: https://ollama.com — no key needed
OLLAMA_BASE_URL=http://localhost:11434

# --- Per-Agent Model Chains (comma-separated, first available wins) ---
# Format: provider/model-id (e.g. openrouter/google/gemma-2-27b-it:free)
ORCHESTRATOR_MODELS=openrouter/google/gemma-2-27b-it:free,ollama/gemma2:9b
SCOUT_MODELS=openrouter/meta-llama/llama-3.3-70b:free,ollama/llama3.2
FORGE_MODELS=openrouter/google/gemma-2-27b-it:free,ollama/gemma2:9b
DEPLOYER_MODELS=ollama/gemma2:9b
MAINTAINER_MODELS=openrouter/google/gemma-2-27b-it:free,ollama/gemma2:9b

# --- Runtime ---
NODE_ENV=development
PORT=4111

# --- Security ---
# Comma-separated allowlist for bash-exec tool in production
# Default (if unset): git,bun,curl,cp,mv,mkdir,cat,ls,echo
BASH_ALLOWLIST=
