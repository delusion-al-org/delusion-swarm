---
import type { HeroSectionProps } from './HeroSection.types';
const {
  title,
  subtitle,
  kicker,
  ctaLabel,
  ctaHref,
  secondaryCtaLabel,
  secondaryCtaHref,
  image,
  align = 'center',
  id,
}: HeroSectionProps = Astro.props;
---
{image ? (
  <section id={id} class="hero min-h-[80vh] bg-base-200">
    <div class="hero-content flex-col lg:flex-row gap-8 max-w-5xl">
      <div class="flex-1">
        {kicker && <span class="badge badge-primary mb-4">{kicker}</span>}
        <h1 class="text-5xl font-bold">{title}</h1>
        {subtitle && <p class="py-6">{subtitle}</p>}
        <div class="flex flex-wrap gap-4">
          <a href={ctaHref} class="btn btn-primary btn-lg">{ctaLabel}</a>
          {secondaryCtaLabel && secondaryCtaHref && (
            <a href={secondaryCtaHref} class="btn btn-outline btn-lg">{secondaryCtaLabel}</a>
          )}
        </div>
      </div>
      <div class="flex-1">
        <img src={image} alt={title} class="w-full rounded-box shadow-lg" />
      </div>
    </div>
  </section>
) : (
  <section id={id} class="hero min-h-[80vh] bg-base-200">
    <div class="hero-content text-center">
      <div class="max-w-md">
        {kicker && <span class="badge badge-primary mb-4">{kicker}</span>}
        <h1 class="text-5xl font-bold">{title}</h1>
        {subtitle && <p class="py-6">{subtitle}</p>}
        <div class="flex flex-wrap justify-center gap-4">
          <a href={ctaHref} class="btn btn-primary btn-lg">{ctaLabel}</a>
          {secondaryCtaLabel && secondaryCtaHref && (
            <a href={secondaryCtaHref} class="btn btn-outline btn-lg">{secondaryCtaLabel}</a>
          )}
        </div>
      </div>
    </div>
  </section>
)}
