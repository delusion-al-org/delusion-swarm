---
import type { MenuSectionProps } from './MenuSection.types';
const { title = 'Our Menu', items }: MenuSectionProps = Astro.props;
---
<section class="py-16 bg-base-100">
  <div class="container mx-auto px-4">
    <h2 class="text-3xl font-bold text-center mb-8">{title}</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {items.map(item => (
        <div class="card bg-base-200 shadow-sm">
          <div class="card-body">
            <div class="flex justify-between items-start">
              <h3 class="card-title">{item.name}</h3>
              <span class="badge badge-primary">{item.price}</span>
            </div>
            {item.description && <p class="text-sm opacity-70">{item.description}</p>}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
