---
import type { ContactSectionProps } from './ContactSection.types';
const { title = 'Contact Us', address, phone, email }: ContactSectionProps = Astro.props;
---
<section class="py-16 bg-base-200">
  <div class="container mx-auto px-4 text-center">
    <h2 class="text-3xl font-bold mb-8">{title}</h2>
    <div class="flex flex-col gap-4 items-center">
      {address && <p class="text-lg"><span class="font-semibold">Address:</span> {address}</p>}
      {phone && <p class="text-lg"><span class="font-semibold">Phone:</span> {phone}</p>}
      {email && <a href={`mailto:${email}`} class="link link-primary">{email}</a>}
    </div>
  </div>
</section>
