---
import type { FeaturesSectionProps } from './FeaturesSection.types';
const { title, subtitle, features, columns = 3, id }: FeaturesSectionProps = Astro.props;
const colClass = { 2: 'md:grid-cols-2', 3: 'md:grid-cols-3', 4: 'md:grid-cols-4' }[columns];
---
<section id={id} class="py-16 bg-base-100">
  <div class="container mx-auto px-4">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold">{title}</h2>
      {subtitle && <p class="mt-3 text-base-content/70 max-w-2xl mx-auto">{subtitle}</p>}
    </div>
    <div class={`grid gap-6 ${colClass}`}>
      {features.map((feature) => (
        <div class="card bg-base-200 shadow-sm">
          <div class="card-body">
            {feature.icon && <div class="text-4xl mb-2">{feature.icon}</div>}
            <h3 class="card-title">{feature.title}</h3>
            <p>{feature.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
