---
import type { CarouselSectionProps } from './CarouselSection.types';
const { title, slides }: CarouselSectionProps = Astro.props;
---
<section class="py-16 bg-base-200">
  <div class="container mx-auto px-4">
    {title && (
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold">{title}</h2>
      </div>
    )}
    <div class="carousel w-full rounded-box">
      {slides.map((slide) => (
        <div class="carousel-item w-full relative">
          <img src={slide.image} alt={slide.title} class="w-full h-64 object-cover" />
          <div class="absolute bottom-0 left-0 right-0 bg-base-300 bg-opacity-80 p-4">
            <h3 class="font-bold text-lg">{slide.title}</h3>
            {slide.description && <p class="text-sm">{slide.description}</p>}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
